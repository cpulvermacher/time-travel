{
    "name": "time-travel",
    "version": "2.4.6",
    "license": "MIT",
    "private": "true",
    "scripts": {
        "build": "sh ./util/build.sh production",
        "dev": "sh ./util/build.sh dev",
        "lint": "tsc && biome check src/ && svelte-check --tsconfig ./tsconfig.json && pnpm lint:translations",
        "lint:translations": "bash ./util/check-translations.sh",
        "fix": "biome check --write src/",
        "prettier": "prettier src --write",
        "test": "vitest --run",
        "checkall": "pnpm test && pnpm lint && pnpm build",
        "machine-translate": "inlang machine translate --project project.inlang"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@inlang/cli": "^3.1.9",
        "@inlang/paraglide-js": "^2.5.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tsconfig/svelte": "^5.0.8",
        "@types/chrome": "^0.1.37",
        "chrome-webstore-upload-cli": "^3.5.0",
        "globals": "^17.4.0",
        "happy-dom": "^20.8.9",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "svelte-check": "^4.4.6",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.0",
        "web-ext": "^10.1.0"
    },
    "dependencies": {
        "@svelte-plugins/datepicker": "^1.0.11",
        "svelte": "^5.53.11"
    },
    "pnpm": {
        "overrides": {
            "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
            "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2"
        }
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
