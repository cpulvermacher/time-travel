{
    "name": "time-travel",
    "version": "2.4.7",
    "license": "MIT",
    "private": "true",
    "scripts": {
        "build": "sh ./util/build.sh production",
        "dev": "sh ./util/build.sh dev",
        "lint": "tsc && biome check *.mts src/ && svelte-check --tsconfig ./tsconfig.json && pnpm lint:translations",
        "lint:translations": "bash ./util/check-translations.sh",
        "fix": "biome check --write src/",
        "test": "vitest --run",
        "coverage": "vitest --run --coverage",
        "checkall": "pnpm test && pnpm lint && pnpm build",
        "machine-translate": "inlang machine translate --project project.inlang"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@inlang/cli": "^3.1.11",
        "@inlang/paraglide-js": "^2.18.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tsconfig/svelte": "^5.0.8",
        "@types/chrome": "^0.1.42",
        "@vitest/coverage-v8": "^4.1.8",
        "chrome-webstore-upload-cli": "^3.5.0",
        "globals": "^17.6.0",
        "happy-dom": "^20.9.0",
        "svelte-check": "^4.4.8",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "web-ext": "^10.1.0"
    },
    "dependencies": {
        "@svelte-plugins/datepicker": "^1.0.11",
        "svelte": "^5.55.7"
    },
    "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
