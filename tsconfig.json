{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "target": "ES2023",
        "useDefineForClassFields": true,
        "lib": ["DOM", "DOM.Iterable", "ES2023"],
        "allowJs": true,
        "skipLibCheck": true,
        "incremental": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": false,
        "noEmit": true,
        "types": ["chrome"]
    },
    "include": ["src/", "*.mts"]
}
